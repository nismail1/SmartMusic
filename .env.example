# Firebase Web App Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Spotify Web API (Client Credentials)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/auth/spotify/callback
VITE_SPOTIFY_SCOPES=user-read-email user-read-private playlist-read-private playlist-read-collaborative streaming user-read-playback-state user-modify-playback-state

# Genius API
VITE_GENIUS_ACCESS_TOKEN=your_genius_access_token
# Optional proxy endpoint for Genius lookups (recommended to avoid browser CORS issues)
VITE_GENIUS_PROXY_ENDPOINT=https://your-domain/getGeniusEnrichment

# Recommendation engine endpoint (Cloud Function / API)
VITE_RECOMMENDATIONS_ENDPOINT=https://your-domain/recommendations

# Spotify → Firebase: deploy with a current CLI (e.g. npm run deploy:functions:spotify-auth), then set the URL printed as "Function URL" (Gen2 is usually https://createspotifyfirebasesession-xxxxx-uc.a.run.app — not the old cloudfunctions.net pattern)
# (If `firebase deploy` errors on engines/node 20, your global firebase-tools is too old; use the npm script or: npx firebase-tools@latest deploy …)
# VITE_SPOTIFY_FIREBASE_SESSION_URL=https://createspotifyfirebasesession-xxxxx-uc.a.run.app
# If you still see signBlob errors after deploy, the function now runs as PROJECT@appspot.gserviceaccount.com. As a fallback, grant the Cloud Run runtime SA
#   roles/iam.serviceAccountTokenCreator on PROJECT@appspot.gserviceaccount.com (Google Cloud → IAM → select appspot@ → grant access to the function’s service account)

# Firestore seeding credentials (service account)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
